{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw Trending Data",
  "description": "Collector Agent 输出的原始采集数据",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "source_agent": { "const": "collector" },
        "created_at": { "type": "string", "format": "date-time" },
        "version": { "type": "string", "pattern": "^v\\d+$" },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "success", "failed", "skipped", "partial"]
        },
        "error": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "enum": ["network_timeout", "parse_error", "filter_empty", "schema_validation_error", "file_not_found", "rate_limited", "internal_error"]
            },
            "message": { "type": "string" }
          },
          "required": ["code", "message"]
        }
      },
      "required": ["source_agent", "created_at", "version", "status"]
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/trending_item" }
    }
  },
  "required": ["meta", "items"],
  "$defs": {
    "trending_item": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "source": { "const": "github_trending" },
        "popularity": {
          "type": "object",
          "properties": {
            "stars": { "type": "integer", "minimum": 0 },
            "stars_today": { "type": "integer", "minimum": 0 }
          },
          "required": ["stars", "stars_today"]
        },
        "language": { "type": "string" },
        "description": { "type": "string" },
        "summary_zh": { "type": "string" }
      },
      "required": ["title", "url", "source", "popularity"]
    }
  }
}