# GitHub API 配置
# 搜索关键词，支持 GitHub Search API 语法
GITHUB_QUERY="AI agent LLM framework"

# 每次采集的仓库数量（默认 15，最多 100）
GITHUB_PER_PAGE=15

# 起始日期，只采集此日期之后更新的仓库（格式: YYYY-MM-DD，留空表示不限制）
GITHUB_SINCE=

# GitHub Personal Access Token（可选，有 Token 可提升限流阈值至 30 次/分钟）
# 生成地址: https://github.com/settings/tokens
GITHUB_TOKEN=

# LLM API 配置
# OpenAI 兼容接口的 Base URL
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名称
LLM_MODEL=deepseek-chat

# API Key（支持 DeepSeek 或任意 OpenAI 兼容接口）
DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# Token 价格（用于成本估算，单位：元/百万 token）
PRICE_INPUT_PER_MILLION=1.0
PRICE_OUTPUT_PER_MILLION=2.0
